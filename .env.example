# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Document Configuration
DOCUMENTS_DIR=./docs_dir
VECTOR_STORE_DIR=./doc_vector_store
COLLECTION_NAME=documents

# LLM Configuration (optional — default gpt-4o-mini)
MODEL_NAME=gpt-4o-mini
MODEL_TEMPERATURE=0.1

# Backend Server Configuration
# Local: API_HOST=localhost  |  Cloud (Render/Railway): API_HOST=0.0.0.0
API_HOST=localhost
API_PORT=8001
# Render/Railway inject PORT automatically — you do not need to set it locally.

# Frontend Configuration (local)
CHAT_ENDPOINT_URL=http://localhost:8001/chat/answer
API_BASE_URL=http://localhost:8001

# After you deploy the API, point the Streamlit app at it (Streamlit Cloud → Secrets or .env):
# API_BASE_URL=https://your-service.onrender.com
# CHAT_ENDPOINT_URL=https://your-service.onrender.com/chat/answer

# Optional: restrict browser CORS to your Streamlit URL (comma-separated)
# CORS_ORIGINS=https://your-app.streamlit.app
